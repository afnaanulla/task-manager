# Server port
PORT=5000

# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT secret key (generate a secure random string, min 32 characters)
JWT_TOKEN=your-super-secret-jwt-key-here

# Allowed CORS origins (comma-separated) - ADD YOUR FRONTEND URL HERE WHEN HOSTING
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app.netlify.app
ALLOWED_ORIGINS=http://localhost:5173
